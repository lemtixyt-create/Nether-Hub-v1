-- TELEPORT HELPERS
-- =========================================================
local function getTargetPlayer()
    local text = PlayerTextBox.Text:lower()
    if text == "" then return nil end
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= Player then
            local n  = p.Name:lower()
            local dn = p.DisplayName:lower()
            if n:sub(1,#text)==text or dn:sub(1,#text)==text then return p end
        end
    end
    return nil
end

local function stopAllTeleports()
    isTpLoopActive = false
    if currentTween then currentTween:Cancel() currentTween=nil end
    local character = Player.Character
    local root = character and character:FindFirstChild("HumanoidRootPart")
    if root then
        root.Velocity = Vector3.new(0,0,0)
        if root:FindFirstChild("TP_Float") then root.TP_Float:Destroy() end
        local bvStop      = Instance.new("BodyVelocity")
        bvStop.Name       = "TP_Float"
            bvStop.MaxForce   = Vector3.new(9e9,9e9,9e9)
            bvStop.Velocity   = Vector3.new(0,0,0)
        bvStop.Parent     = root
        task.delay(0.5, function() if bvStop then bvStop:Destroy() end end)
    end
    notify("Nether6029 Hub", "Teleport stopped.", 2)
end

local function doTweenTP()
    stopAllTeleports()
    local target    = getTargetPlayer()
    local character = Player.Character
    local root      = character and character:FindFirstChild("HumanoidRootPart")
    if not target or not target.Character then
        notify("Nether6029 Hub", "Target not found!", 3) return
    end
    local targetRoot = target.Character:FindFirstChild("HumanoidRootPart")
    if not targetRoot or not root then return end

    local floatBV       = Instance.new("BodyVelocity")
    floatBV.Name        = "TP_Float"
    floatBV.MaxForce    = Vector3.new(9e9,9e9,9e9)
    floatBV.Velocity    = Vector3.new(0,0,0)
    floatBV.Parent      = root

    local distance  = (root.Position - targetRoot.Position).Magnitude
    local duration  = math.clamp(distance / 250, 0.2, 3)
    local tweenInfo = TweenInfo.new(duration, Enum.EasingStyle.Quad, Enum.EasingDirection.InOut)
    currentTween    = TweenService:Create(root, tweenInfo, {CFrame = targetRoot.CFrame + Vector3.new(0,3,0)})
    currentTween:Play()
    currentTween.Completed:Connect(function() if floatBV then floatBV:Destroy() end end)
    notify("Nether6029 Hub", "Tween TP → " .. target.DisplayName, 3)
end

local function doBypassTP()
    stopAllTeleports()
    local target    = getTargetPlayer()
    local character = Player.Character
    local root      = character and character:FindFirstChild("HumanoidRootPart")
    if not target or not target.Character then
        notify("Nether6029 Hub", "Target not found!", 3) return
    end
    local targetRoot = target.Character:FindFirstChild("HumanoidRootPart")
    if not targetRoot or not root then return end

    isTpLoopActive = true
    local startPos  = root.Position
    local endPos    = targetRoot.Position
    local diff      = endPos - startPos
    local stepSize  = 300
    local steps     = math.max(math.floor(diff.Magnitude / stepSize), 1)

    task.spawn(function()
        for i = 1, steps do
            if not isTpLoopActive or not root or not root.Parent then break end
            root.CFrame   = CFrame.new(startPos + diff.Unit * (i * stepSize))
            root.Velocity = Vector3.new(0,0,0)
            RunService.Heartbeat:Wait()
        end
        if isTpLoopActive and root and root.Parent and targetRoot and targetRoot.Parent then
            root.CFrame = targetRoot.CFrame + Vector3.new(0,2,0)
        end
        isTpLoopActive = false
    end)
    notify("Nether6029 Hub", "Bypass TP → " .. target.DisplayName, 3)
end

