local function makeSplitRow(btnA_text, btnA_color, btnB_text, btnB_color)
    local row = Instance.new("Frame")
    row.Size            = UDim2.new(1, 0, 0, 38)
    row.BackgroundTransparency = 1
    row.LayoutOrder     = nextOrder()
    row.Parent          = ScrollFrame

    local layout = Instance.new("UIListLayout")
    layout.FillDirection = Enum.FillDirection.Horizontal
    layout.Padding       = UDim.new(0, 8)
    layout.Parent        = row

    local function halfBtn(text, color)
        local b = Instance.new("TextButton")
        b.Size            = UDim2.new(0.5, -4, 1, 0)
        b.BackgroundColor3= color
        b.Text            = text
        b.TextColor3      = Color3.fromRGB(255,255,255)
        b.TextSize        = 12
        b.Font             = Enum.Font.GothamBold
        b.BorderSizePixel = 0
        b.Parent          = row
        Instance.new("UICorner", b).CornerRadius = UDim.new(0,8)
        local bConn = nil
        b.MouseEnter:Connect(function()
            makeTween(b,{BackgroundTransparency=0.2, Size=UDim2.new(0.5,2,1,4)},0.12):Play()
            if bConn then bConn:Disconnect() bConn = nil end
            bConn = RunService.RenderStepped:Connect(function()
                local mouse = UserInputService:GetMouseLocation()
                local centerX = b.AbsolutePosition.X + b.AbsoluteSize.X/2
                local dx = (mouse.X - centerX) / (b.AbsoluteSize.X/2)
                dx = math.clamp(dx, -1, 1)
                b.Rotation = dx * 6
            end)
        end)
        b.MouseLeave:Connect(function()
            if bConn then bConn:Disconnect() bConn = nil end
            makeTween(b,{BackgroundTransparency=0, Size=UDim2.new(0.5,-4,1,0), Rotation=0},0.12):Play()
        end)
        return b
    end

    return halfBtn(btnA_text, btnA_color), halfBtn(btnB_text, btnB_color), row
end

