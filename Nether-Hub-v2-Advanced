local function makeToggleBtn(labelOff, labelOn, colorOff, colorOn, hotkey)
    local btn = Instance.new("TextButton")
    btn.Size            = UDim2.new(1, 0, 0, 40)
    btn.BackgroundColor3= colorOff
    btn.Text            = labelOff .. (hotkey and ("  [" .. hotkey .. "]") or "")
    btn.TextColor3      = Color3.fromRGB(255,255,255)
    btn.TextSize        = 13
    btn.Font             = Enum.Font.GothamBold
    btn.BorderSizePixel = 0
    btn.LayoutOrder     = nextOrder()
    btn.Parent          = ScrollFrame
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0,8)

    local inStroke = Instance.new("UIStroke")
    inStroke.Thickness = 1
    inStroke.Color     = Color3.fromRGB(255,255,255)
    inStroke.Transparency = 0.85
    inStroke.Parent    = btn

    local hoverConn = nil
    btn.MouseEnter:Connect(function()
        makeTween(btn, {BackgroundTransparency=0.15, Size=UDim2.new(1,8,0,44)}, 0.12):Play()
        if hoverConn then hoverConn:Disconnect() hoverConn = nil end
        hoverConn = RunService.RenderStepped:Connect(function()
            local mouse = UserInputService:GetMouseLocation()
            local centerX = btn.AbsolutePosition.X + btn.AbsoluteSize.X/2
            local dx = (mouse.X - centerX) / (btn.AbsoluteSize.X/2)
            dx = math.clamp(dx, -1, 1)
            btn.Rotation = dx * 6
        end)
    end)
    btn.MouseLeave:Connect(function()
        if hoverConn then hoverConn:Disconnect() hoverConn = nil end
        makeTween(btn, {BackgroundTransparency=0, Size=UDim2.new(1,0,0,40), Rotation=0}, 0.12):Play()
    end)

    local state = false
    local function setState(on)
        state = on
        if on then
            btn.Text            = labelOn  .. (hotkey and ("  [" .. hotkey .. "]") or "")
            btn.BackgroundColor3= colorOn
        else
            btn.Text            = labelOff .. (hotkey and ("  [" .. hotkey .. "]") or "")
            btn.BackgroundColor3= colorOff
        end
    end
    btn.MouseButton1Down:Connect(function()
        pcall(function() clickSound:Play() end)
        makeTween(btn, {Size=UDim2.new(1,-4,0,38)}, 0.07):Play()
    end)
    btn.MouseButton1Up:Connect(function()
        makeTween(btn, {Size=UDim2.new(1,0,0,40)}, 0.07):Play()
    end)
    return btn, setState, function() return state end
end

