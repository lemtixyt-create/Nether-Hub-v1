-- ESP LOGIC
-- =========================================================
local function getLevel(p)
    if p:FindFirstChild("Data") and p.Data:FindFirstChild("Level") then
        return p.Data.Level.Value
    elseif p:FindFirstChild("leaderstats") and p.leaderstats:FindFirstChild("Level") then
        return p.leaderstats.Level.Value
    end
    return "?"
end

local function createESP(p)
    if p == Player then return end
    local function applyESP(character)
        local head = character:WaitForChild("Head",5)
        if not head then return end
        if head:FindFirstChild("N6_ESP") then head.N6_ESP:Destroy() end

        local bbg = Instance.new("BillboardGui")
        bbg.Name         = "N6_ESP"
        bbg.Size         = UDim2.new(0,220,0,60)
        bbg.AlwaysOnTop  = true
        bbg.ExtentsOffset= Vector3.new(0,3,0)
        bbg.Parent       = head

        local bg2 = Instance.new("Frame")
        bg2.Size            = UDim2.new(1,0,1,0)
        bg2.BackgroundColor3= Color3.fromRGB(0,0,0)
        bg2.BackgroundTransparency=0.5
        bg2.BorderSizePixel=0
        bg2.Parent=bbg
        Instance.new("UICorner",bg2).CornerRadius=UDim.new(0,6)

        local textLabel = Instance.new("TextLabel")
        textLabel.Size              = UDim2.new(1,0,1,0)
        textLabel.BackgroundTransparency=1
        textLabel.TextSize          = 13
        textLabel.Font               = Enum.Font.GothamBold
        textLabel.TextStrokeTransparency=0
        textLabel.TextStrokeColor3  = Color3.fromRGB(0,0,0)
        textLabel.Parent            = bbg

        local conn
        conn = RunService.Heartbeat:Connect(function()
            if not espActive or not head or not head:FindFirstChild("N6_ESP") then
                if conn then conn:Disconnect() end
                pcall(function() bbg:Destroy() end)
                return
            end
            local hum = character:FindFirstChildOfClass("Humanoid")
            if not hum then return end
            local hp    = math.floor(hum.Health)
            local maxHp = math.floor(hum.MaxHealth)
            local lvl   = getLevel(p)
            local dist  = math.floor((Camera.CFrame.Position - head.Position).Magnitude)
            textLabel.Text = string.format("[ %s ]\nLv.%s  |  HP: %d/%d  |  %dm", p.DisplayName, tostring(lvl), hp, maxHp, dist)
            local pct = math.clamp(hum.Health/hum.MaxHealth, 0, 1)
            textLabel.TextColor3 = Color3.fromRGB(255, math.floor(pct*255), math.floor(pct*100))
        end)
    end
    if p.Character then task.spawn(function() applyESP(p.Character) end) end
    p.CharacterAdded:Connect(applyESP)
end

