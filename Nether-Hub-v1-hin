-- भाग 5: एंटी-चीट बाईपास एन्हांसमेंट (Advanced Bypass)
-- =========================================================

-- 1. नो-क्लिप बाईपास (No-Clip Detection Avoidance)
-- सामान्य नो-क्लिप को गेम डिटेक्ट कर लेते हैं, इसलिए यह तकनीक 
-- केवल पैरों और धड़ के मुख्य हिस्से को छद्म तरीके से पास कराती है
local function advancedNoclipBypass()
    RunService.RenderStepped:Connect(function()
        if noclip and Player.Character then
            -- Humanoid का स्टेट बदलना ताकि गेम इंजन इसे 'गिरता हुआ' समझे
            local humanoid = Player.Character:FindFirstChildOfClass("Humanoid")
            if humanoid then
                humanoid:ChangeState(Enum.HumanoidStateType.Physics)
            end
            
            -- केवल आवश्यक अंगों को पारगम्य (Non-collidable) बनाना
            for _, part in pairs(Player.Character:GetChildren()) do
                if part:IsA("BasePart") then
                    part.CanCollide = false
                end
            end
        end
    end)
end
task.spawn(advancedNoclipBypass)

-- 2. नेटवर्क ओनरशिप और वेलोसिटी बाईपास (Speed & Fly Anti-Rubberband)
-- जब आप तेज़ी से उड़ते हैं या चलते हैं, तो सर्वर आपको वापस खींचता है (Rubberbanding)।
-- यह फंक्शन लगातार कैरेक्टर की लीनियर वेलोसिटी को रीसेट करता है ताकि लॉग न बने।
local function velocityBypass()
    RunService.Heartbeat:Connect(function()
        if Player.Character and (flying or frozen) then
            local root = Player.Character:FindFirstChild("HumanoidRootPart")
            if root then
                -- असेंबली वेलोसिटी को नियंत्रित करना ताकि सर्वर अलर्ट ट्रिगर न हो
                local currentVel = root.AssemblyLinearVelocity
                if frozen then
                    root.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
                    root.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
                elseif flying then
                    -- फ्लाई के दौरान अचानक गिरने की गति को रोकना
                    root.AssemblyLinearVelocity = Vector3.new(currentVel.X, 0, currentVel.Z)
                end
            end
        end
    end)
end
task.spawn(velocityBypass)

-- 3. वॉकस्पीड रीसेट प्रिवेंशन (WalkSpeed Anti-Reset)
-- कई गेम स्क्रिप्ट स्क्रिप्टेड स्पीड को हर सेकंड 16 पर बदल देती हैं।
-- यह हुक (Hook) प्रॉपर्टी में होने वाले बदलावों को ओवरराइड करता है।
local function setupSpeedHook()
    Player.CharacterAdded:Connect(function(char)
        local humanoid = char:WaitForChild("Humanoid")
        humanoid:GetPropertyChangedSignal("WalkSpeed"):Connect(function()
            if humanoid.WalkSpeed ~= walkSpeed and not frozen and not flying then
                humanoid.WalkSpeed = walkSpeed
            end
        end)
    end)
end
task.spawn(setupSpeedHook)
