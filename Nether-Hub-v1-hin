-- Blox Fruits प्लेयर का लेवल निकालने का फंक्शन
local function getBloxFruitsLevel(p)
    -- विधि 1: Blox Fruits मुख्य डेटा मैनेजर से खोजना
    if p:FindFirstChild("Data") and p.Data:FindFirstChild("Level") then
        return p.Data.Level.Value
    -- विधि 2: सामान्य लीडरस्टैट्स से खोजना
    elseif p:FindFirstChild("leaderstats") and p.leaderstats:FindFirstChild("Level") then
        return p.leaderstats.Level.Value
    end
    return "???" -- यदि लेवल लोड न हुआ हो
end

-- एकल खिलाड़ी के लिए ESP बनाने का लॉजिक
local function createESP(p)
    if p == Player then return end
    
    local function applyESP(character)
        local head = character:WaitForChild("Head", 5)
        if not head then return end
        
        -- पुराना ESP हटाना अगर पहले से मौजूद हो
        if head:FindFirstChild("NetherESP") then head.NetherESP:Destroy() end
        
        -- Billboard GUI ऑब्जेक्ट निर्माण
        local bbg = Instance.new("BillboardGui")
        bbg.Name = "NetherESP"
        bbg.Size = UDim2.new(0, 200, 0, 50)
        bbg.AlwaysOnTop = true -- दीवारों के पार दिखने के लिए आवश्यक
        bbg.ExtentsOffset = Vector3.new(0, 3, 0)
        bbg.Parent = head
        
        local textLabel = Instance.new("TextLabel")
        textLabel.Size = UDim2.new(1, 0, 1, 0)
        textLabel.BackgroundTransparency = 1
        textLabel.TextSize = 13
        textLabel.Font = Enum.Font.SourceSansBold
        textLabel.TextStrokeTransparency = 0 -- टेक्स्ट को स्पष्ट रखने के लिए आउटलाइन
        textLabel.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
        textLabel.Parent = bbg
        
        -- रीयल-टाइम हेल्थ और लेवल ट्रैकर लूप
        local espConnection
        espConnection = RunService.Heartbeat:Connect(function()
            if not espActive or not character or not character:FindFirstChild("Humanoid") or not head:FindFirstChild("NetherESP") then
                if espConnection then espConnection:Disconnect() end
                bbg:Destroy()
                return
            end
            
            local humanoid = character.Humanoid
            local hp = math.floor(humanoid.Health)
            local maxHp = math.floor(humanoid.MaxHealth)
            local lvl = getBloxFruitsLevel(p)
            
            -- डिस्प्ले टेक्स्ट फॉर्मेट
            textLabel.Text = string.format("%s\n[Lv. %s] [HP: %d/%d]", p.DisplayName, tostring(lvl), hp, maxHp)
            
            -- हेल्थ के आधार पर रंग बदलना (कम हेल्थ = लाल, फुल हेल्थ = हरा)
            local hpPercent = humanoid.Health / humanoid.MaxHealth
            textLabel.TextColor3 = Color3.fromRGB(255, 255, 255):Lerp(Color3.fromRGB(255, 50, 50), 1 - hpPercent)
        end)
    end
    
    if p.Character then task.spawn(function() applyESP(p.Character) end) end
    p.CharacterAdded:Connect(applyESP)
end

