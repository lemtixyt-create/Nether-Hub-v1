-- 1. No-Clip Detection Avoidance
local function advancedNoclipBypass()
    RunService.RenderStepped:Connect(function()
        if noclip and Player.Character then
            -- Changing Humanoid state so engine thinks it's falling
            local humanoid = Player.Character:FindFirstChildOfClass("Humanoid")
            if humanoid then
                humanoid:ChangeState(Enum.HumanoidStateType.Physics)
            end
            
            -- Setting only necessary parts to non-collidable
            for _, part in pairs(Player.Character:GetChildren()) do
                if part:IsA("BasePart") then
                    part.CanCollide = false
                end
            end
        end
    end)
end
task.spawn(advancedNoclipBypass)

-- 2. Network Ownership and Velocity Bypass
local function velocityBypass()
    RunService.Heartbeat:Connect(function()
        if Player.Character and (flying or frozen) then
            local root = Player.Character:FindFirstChild("HumanoidRootPart")
            if root then
                -- Controlling assembly velocity to avoid server alerts
                local currentVel = root.AssemblyLinearVelocity
                if frozen then
                    root.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
                    root.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
                elseif flying then
                    -- Prevent falling speed during flight
                    root.AssemblyLinearVelocity = Vector3.new(currentVel.X, 0, currentVel.Z)
                end
            end
        end
    end)
end
task.spawn(velocityBypass)

-- 3. WalkSpeed Anti-Reset
local function setupSpeedHook()
    Player.CharacterAdded:Connect(function(char)
        local humanoid = char:WaitForChild("Humanoid")
        humanoid:GetPropertyChangedSignal("WalkSpeed"):Connect(function()
            if humanoid.WalkSpeed ~= walkSpeed and not frozen and not flying then
                humanoid.WalkSpeed = walkSpeed
            end
        end)
    end)
end
task.spawn(setupSpeedHook)

