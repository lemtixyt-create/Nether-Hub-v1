local function getTargetPlayer()
    local text = PlayerTextBox.Text:lower()
    if text == "" then return nil end
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= Player and (p.Name:lower():sub(1, #text) == text or p.DisplayName:lower():sub(1, #text) == text) then
            return p
        end
    end
    return nil
end

local function stopAllTeleports()
    isTpLoopActive = false 
    
    if currentTween then
        currentTween:Cancel()
        currentTween = nil
    end
    
    local character = Player.Character
    local root = character and character:FindFirstChild("HumanoidRootPart")
    if root then
        root.Velocity = Vector3.new(0, 0, 0)
        if root:FindFirstChild("TP_Float") then root.TP_Float:Destroy() end
        
        local bv = Instance.new("BodyVelocity")
        bv.Name = "TP_Float"
        bv.maxForce = Vector3.new(9e9, 9e9, 9e9)
        bv.velocity = Vector3.new(0, 0, 0)
        bv.Parent = root
        task.delay(0.5, function() if bv then bv:Destroy() end end)
    end
end

