BypassButton.MouseButton1Click:Connect(function()
    stopAllTeleports()
    local target = getTargetPlayer()
    local character = Player.Character
    local root = character and character:FindFirstChild("HumanoidRootPart")
    
    if target and target.Character and target.Character:FindFirstChild("HumanoidRootPart") and root then
        isTpLoopActive = true
        local targetRoot = target.Character.HumanoidRootPart
        local startPos = root.Position
        local endPos = targetRoot.Position
        local diff = endPos - startPos
        local steps = math.floor(diff.Magnitude / 25)
        
        task.spawn(function()
            for i = 1, steps do
                if not isTpLoopActive or not root or not targetRoot then break end
                root.CFrame = CFrame.new(startPos + (diff.Unit * (i * 25)))
                root.Velocity = Vector3.new(0, 0, 0)
                RunService.Heartbeat:Wait()
            end
            if isTpLoopActive and root and targetRoot then
                root.CFrame = targetRoot.CFrame + Vector3.new(0, 2, 0)
            end
        end)
    end
end)

